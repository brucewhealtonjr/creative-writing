{#
/**
 * @file
 * Theme override to display a book tree.
 */
#}
{% import _self as book_tree %}

{{ book_tree.book_links(items, attributes, 0) }}

{% macro book_links(items, attributes, menu_level) %}
  {% import _self as book_tree %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes }}>
    {% else %}
      <ul>
    {% endif %}
    {% for item in items %}
      <li{{ item.attributes }}>
        {% if item.label_only and item.below %}
          <details class="book-tree__section"{{ item.in_active_trail ? ' open' }}>
            <summary class="book-tree__label">{{ item.title }}</summary>
            {{ book_tree.book_links(item.below, attributes, menu_level + 1) }}
          </details>
        {% elseif item.label_only %}
          <span class="book-tree__label">{{ item.title }}</span>
        {% else %}
          {{ link(item.title, item.url) }}
          {% if item.below %}
            {{ book_tree.book_links(item.below, attributes, menu_level + 1) }}
          {% endif %}
        {% endif %}
      </li>
    {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}
