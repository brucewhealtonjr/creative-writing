{#
/**
 * @file
 * Theme override for book cover and description teaser nodes.
 */
#}
{% set node_classes = [
  'node',
  'node--type-' ~ node.bundle|clean_class,
  'node--view-mode-' ~ view_mode|clean_class,
  not node.isPublished() ? 'node--unpublished',
  'card',
  'h-100',
  'border-0',
  'shadow-sm',
  'bg-white',
  'text-dark',
  'book-teaser-card'
] %}

<article{{ attributes.addClass(node_classes) }} style="border-radius: 8px; overflow: hidden; transition: transform 0.25s ease, box-shadow 0.25s ease;">
  {% if content.field_book_cover_page is not empty %}
    <div class="card-img-top-wrapper p-3 d-flex align-items-center justify-content-center" style="height: 170px; overflow: hidden;">
      {{ content.field_book_cover_page }}
    </div>
  {% endif %}
  
  <div class="card-body d-flex flex-column p-3">
    {{ title_prefix }}
    <h3{{ title_attributes.addClass('card-title', 'h4', 'mb-2', 'fw-bold') }}>
      <a href="{{ url }}" rel="bookmark" class="text-dark text-decoration-none hover-gold">{{ label }}</a>
    </h3>
    {{ title_suffix }}
    
    <div class="card-text text-muted flex-grow-1 mb-3" style="font-size: 0.95rem; line-height: 1.6; opacity: 0.85;">
      {{ content.body }}
    </div>
    
    <div class="mt-auto pt-2">
      <a href="{{ url }}" class="btn btn-outline-warning btn-sm w-100 fw-semibold text-uppercase" style="letter-spacing: 0.5px;">Read Book Details</a>
    </div>
  </div>
</article>
